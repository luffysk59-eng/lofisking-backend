# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE (Supabase / AWS RDS PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:5432/lofisking

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── REDIS (Upstash / local) ──
REDIS_URL=redis://localhost:6379

# ── AWS S3 (video storage) ──
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=lofisking-videos

# ── ANTHROPIC AI ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── INSTAGRAM OAuth ──
INSTAGRAM_APP_ID=your_facebook_app_id
INSTAGRAM_APP_SECRET=your_facebook_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/instagram/callback

# ── EMAIL (OTP / notifications) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=LOFISKING <noreply@lofisking.com>

# ── FRONTEND URL (CORS) ──
FRONTEND_URL=http://localhost:3000

# ── OTP ──
OTP_EXPIRES_MINS=10
